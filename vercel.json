{
  "version": 2,
  "name": "lamubi-principal",
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/tickets/(.*)",
      "dest": "/tickets/index.html"
    },
    {
      "src": "/registro/(.*)",
      "dest": "/registro/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
